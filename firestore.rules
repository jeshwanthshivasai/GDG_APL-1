rules_version = '2';

// ===============================================================
// DAIY Analytics — Firestore Security Rules (Prototype)
// Database: daiy-analytics
// ===============================================================
//
// Data Model:
// Collection: sessions
// Document ID: auto-generated UUID (client-side)
// Fields:
//   - sessionId: string (required, matches document ID)
//   - timestamp: string (required, ISO 8601)
//   - userAgent: string (required, max 500 chars)
//   - language: string (required, max 10 chars)
//   - screenSize: string (required, max 20 chars)
//   - viewportSize: string (required, max 20 chars)
//   - platform: string (required, max 50 chars)
//   - referrer: string (optional, max 500 chars)
//   - timezone: string (required, max 100 chars)
//   - darkMode: bool (required)
//   - cameraUsed: bool (required)
//   - queriesCount: number (required, >= 0)
//   - queries: list (required, max 50 items)
//   - location: map (optional — lat, lng, city, country)
//
// Access Pattern: Anonymous write-only (no auth required).
// Read access is restricted to Firebase Console / Admin SDK only.
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Sessions collection — public create + update, no read
    match /sessions/{sessionId} {

      // Allow creating a new session document
      allow create: if isValidSessionCreate(request.resource.data);

      // Allow updating an existing session (appending queries, updating counts)
      allow update: if isValidSessionUpdate(request.resource.data);

      // NEVER allow client reads or deletes
      allow read: if false;
      allow delete: if false;
    }

    // Deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// --- Validation Functions ---

function isValidSessionCreate(data) {
  return data.keys().hasAll(['sessionId', 'timestamp', 'queriesCount', 'queries']) &&
         data.sessionId is string && data.sessionId.size() > 0 && data.sessionId.size() <= 50 &&
         data.timestamp is string && data.timestamp.size() <= 30 &&
         data.queriesCount is number && data.queriesCount >= 0 &&
         data.queries is list && data.queries.size() <= 100;
}

function isValidSessionUpdate(data) {
  return data.queriesCount is number && data.queriesCount >= 0 &&
         data.queries is list && data.queries.size() <= 100 &&
         // Immutable fields cannot change
         data.sessionId == resource.data.sessionId &&
         data.timestamp == resource.data.timestamp;
}
